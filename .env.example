# ==========================================
# 秒杀系统 — 环境变量模板
# 说明: 复制此文件为 .env 并填入真实值
# 安全: 此文件可提交到 Git（所有敏感值已替换为占位符）
# ==========================================

# ---------- 服务端口 ----------
SERVER_PORT=8080

# ---------- MySQL ----------
DB_HOST=localhost
DB_PORT=3307
DB_NAME=seckill
DB_USERNAME=your_db_username
DB_PASSWORD=your_db_password_here

# ---------- Redis ----------
REDIS_HOST=localhost
REDIS_PORT=6380
REDIS_PASSWORD=your_redis_password_here

# ---------- RabbitMQ ----------
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=your_rabbitmq_username
RABBITMQ_PASSWORD=your_rabbitmq_password_here

# ---------- JWT ----------
# 请使用随机生成的 256 位以上密钥（生产环境务必更换）
JWT_SECRET=your_jwt_secret_here_generate_a_random_256bit_key
JWT_EXPIRATION=86400000

# ---------- Snowflake ----------
SNOWFLAKE_WORKER_ID=1
SNOWFLAKE_DATACENTER_ID=1

# ---------- Docker (docker-compose 使用) ----------
MYSQL_ROOT_PASSWORD=your_db_password_here
REDIS_REQUIREPASS=your_redis_password_here
RABBITMQ_DEFAULT_USER=your_rabbitmq_username
RABBITMQ_DEFAULT_PASS=your_rabbitmq_password_here
